# Environment variables (not used in this project)
# This file is for reference only

# The application uses config files instead:
# - Frontend: vite.config.ts
# - Backend: api/config/app.php and api/config/database.php

# For local development:
# 1. Ensure XAMPP/local server is running
# 2. Database credentials are in api/config/database.php
# 3. Run: npm run dev

# For production:
# 1. Edit api/config/app.php with production settings
# 2. Edit api/config/database.php with production database
# 3. Build: npm run build
# 4. Deploy dist/ to hosting
